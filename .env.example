# GitHub Repository Configuration
# Your GitHub repository in format: username/repository
REPO=wesleykirkland/docker-runner

# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
# Required scope: repo (for repository-specific runners)
ACCESS_TOKEN=your_github_personal_access_token_here

# Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Edit .env and replace the values above
# 3. Never commit .env to version control
# 4. Use with docker compose: docker compose --env-file .env up -d

